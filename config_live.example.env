# Binance USD-M Futures live-candidate configuration.
# Do not put real secrets in source control. Copy this to .env locally.

# Demo/Testnet credentials. Prefer a dedicated Binance Futures Demo Trading API key.
BINANCE_FUTURES_DEMO_API_KEY=replace_me
BINANCE_FUTURES_DEMO_API_SECRET=replace_me

# The runner maps these demo aliases into BINANCE_FUTURES_API_KEY/SECRET when --mainnet is not used.
# Leave generic keys empty unless you intentionally run a different environment.
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# Hard-restricted strategy scope. Changing these should make the runner abort.
FUTURES_SYMBOL=BTCUSDT
FUTURES_INTERVAL=1h

# Conservative demo/test order sizing.
MAX_NOTIONAL_USDT=25
TEST_ORDER_NOTIONAL_USDT=25
LEVERAGE=1
MARGIN_TYPE=ISOLATED

# Required to allow real orders on Binance Demo/Futures Testnet with --mode demo-supervised.
# Keep false for observe and dry-run checks.
DEMO_TRADING=false

# Required for supervised live mode only.
# Dry-run/testnet/observe modes do not require these live unlocks.
LIVE_TRADING=false
LIVE_TRADING_MANUAL_CONFIRMATION=

# To unlock live manually, after all checklist items pass:
# LIVE_TRADING=true
# LIVE_TRADING_MANUAL_CONFIRMATION=BTCUSDT_1H_SHORT_ONLY
